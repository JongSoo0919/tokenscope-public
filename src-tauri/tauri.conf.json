{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TokenScope",
  "version": "0.1.0",
  "identifier": "com.tokenscope.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "yarn dev",
    "beforeBuildCommand": "yarn build"
  },
  "app": {
    "windows": [
      {
        "title": "TokenScope",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "fs": {
      "scope": ["$HOME/.claude/**", "$HOME/.tokenscope/**"],
      "all": false
    }
  }
}
