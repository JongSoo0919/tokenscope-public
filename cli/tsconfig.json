  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": [
    "./**/*.ts",
    "../src/lib/analyzer.ts",
    "../src/lib/parser.ts",
    "../src/lib/providers.ts"
  ]
